{
	"name": "ghactivities",
	"version": "0.4.0",
	"description": "",
	"keywords": [
		"ai",
		"rules",
		"cli",
		"copilot",
		"cursor",
		"cline",
		"configuration",
		"development"
	],
	"homepage": "https://github.com/dyoshikawa/ghevents#readme",
	"bugs": {
		"url": "https://github.com/dyoshikawa/ghevents/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/dyoshikawa/ghevents.git"
	},
	"license": "MIT",
	"author": "dyoshikawa",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"ghevents": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"check": "bun run fmt:check && bun run oxlint && bun run typecheck",
		"cicheck": "bun run cicheck:code && bun run cicheck:content",
		"cicheck:code": "bun run check && bun run test",
		"cicheck:content": "bun run cspell && bun run secretlint",
		"cspell": "cspell --no-progress --gitignore .",
		"dev": "bun run src/cli/index.ts",
		"fix": "bun run fmt && bun run oxlint:fix",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"oxlint": "oxlint . --max-warnings 0",
		"oxlint:fix": "oxlint . --fix --max-warnings 0",
		"prepublishOnly": "bun run build",
		"secretlint": "secretlint --secretlintignore .gitignore \"**/*\"",
		"sort": "sort-package-json",
		"test": "vitest run --silent",
		"test:coverage": "vitest run --coverage --silent",
		"test:watch": "vitest --silent",
		"typecheck": "tsgo --noEmit",
		"prepare": "simple-git-hooks && bunx rulesync generate"
	},
	"simple-git-hooks": {
		"pre-commit": "bunx lint-staged"
	},
	"dependencies": {
		"@clack/prompts": "1.0.0",
		"@octokit/graphql": "9.0.3",
		"@octokit/rest": "22.0.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@secretlint/secretlint-rule-preset-recommend": "11.3.1",
		"@tsconfig/node24": "24.0.4",
		"@types/node": "25.2.2",
		"@typescript/native-preview": "7.0.0-dev.20260208.1",
		"@vitest/coverage-v8": "4.0.18",
		"cspell": "9.6.4",
		"lint-staged": "16.2.7",
		"oxfmt": "0.28.0",
		"oxlint": "1.43.0",
		"secretlint": "11.3.1",
		"simple-git-hooks": "2.13.1",
		"sort-package-json": "3.6.1",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}

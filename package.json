{
	"name": "ghactivities",
	"version": "0.4.0",
	"description": "",
	"keywords": [
		"ai",
		"rules",
		"cli",
		"copilot",
		"cursor",
		"cline",
		"configuration",
		"development"
	],
	"homepage": "https://github.com/dyoshikawa/ghevents#readme",
	"bugs": {
		"url": "https://github.com/dyoshikawa/ghevents/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/dyoshikawa/ghevents.git"
	},
	"license": "MIT",
	"author": "dyoshikawa",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"ghevents": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"check": "pnpm run fmt:check && pnpm run oxlint && pnpm run typecheck",
		"cicheck": "pnpm run cicheck:code && pnpm run cicheck:content",
		"cicheck:code": "pnpm run check && pnpm run test",
		"cicheck:content": "pnpm run cspell && pnpm run secretlint",
		"cspell": "cspell --no-progress --gitignore .",
		"dev": "tsx src/cli/index.ts",
		"fix": "pnpm run fmt && pnpm run oxlint:fix",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"oxlint": "oxlint . --max-warnings 0",
		"oxlint:fix": "oxlint . --fix --max-warnings 0",
		"prepublishOnly": "pnpm build",
		"secretlint": "secretlint --secretlintignore .gitignore \"**/*\"",
		"sort": "sort-package-json",
		"test": "vitest run --silent",
		"test:coverage": "vitest run --coverage --silent",
		"test:watch": "vitest --silent",
		"typecheck": "tsgo --noEmit",
		"prepare": "simple-git-hooks && npx rulesync generate"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm exec lint-staged"
	},
	"dependencies": {
		"@octokit/graphql": "9.0.1",
		"@octokit/rest": "22.0.0"
	},
	"devDependencies": {
		"@secretlint/secretlint-rule-preset-recommend": "10.1.0",
		"@tsconfig/node24": "24.0.1",
		"@types/node": "24.0.3",
		"@typescript/native-preview": "7.0.0-dev.20250623.1",
		"@vitest/coverage-v8": "3.2.4",
		"cspell": "9.1.2",
		"lint-staged": "16.1.2",
		"oxfmt": "0.28.0",
		"oxlint": "1.4.0",
		"secretlint": "10.1.0",
		"simple-git-hooks": "2.13.0",
		"sort-package-json": "3.2.1",
		"tsup": "8.5.0",
		"tsx": "4.20.3",
		"typescript": "5.8.3",
		"vitest": "3.2.4"
	},
	"packageManager": "pnpm@10.12.2",
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}

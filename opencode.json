{
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--enable-web-dashboard",
        "false",
        "--project",
        "."
      ],
      "enabled": true,
      "environment": {}
    }
  },
  "instructions": [
    ".opencode/memories/coding-guidelines.md",
    ".opencode/memories/feature-change-guidelines.md",
    ".opencode/memories/testing-guidelines.md"
  ]
}
